# App URL (NextAuth)
AUTH_URL=http://localhost:3000
AUTH_SECRET=generate-with-openssl-rand-base64-32

# Netlify (production): set AUTH_URL to your site URL, no trailing slash, e.g.
# AUTH_URL=https://your-site-name.netlify.app
# Also set the same in Netlify UI → Site settings → Environment variables.
# Optional: NEXT_PUBLIC_APP_URL same value (share links / emails).

# Database — same pattern as Roar Data (Prisma + Supabase)
# DATABASE_URL = Transaction pooler (Supabase: port 6543, "Transaction" mode in dashboard)
# DIRECT_URL   = Direct / session connection (Supabase: port 5432, "Session" or direct host)
# If you use Neon/Railway/single URL only, paste the same string into both variables.
DATABASE_URL=postgresql://USER:PASSWORD@POOLER_HOST:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require

# Gemini (blog generation: Next.js admin + Python cron agent)
GEMINI_API_KEY=
# Optional override; default in code is gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash
# Free tier has low daily limits; enable billing in Google AI Studio or let clients add BYOK in Business profile.

# Blog + social images default to rule-based topic art under public/images/blog/*.svg (no image API billing).
# Optional: enable Google Imagen (same key as Gemini when your project allows it):
# BLOG_COVER_MODE=imagen
# SOCIAL_IMAGE_MODE=imagen
# GEMINI_IMAGE_MODEL=imagen-4.0-fast-generate-001
# DISABLE_IMAGEN=1

# PageSpeed Insights API (same Google Cloud project: enable “PageSpeed Insights API”)
# Powers Lighthouse scores in Site audit (performance, SEO, accessibility, best practices).
PAGESPEED_INSIGHTS_API_KEY=

# Google Search Console (OAuth 2.0, read-only). Enable Search Console API; OAuth client Web type.
# Authorized redirect URIs (same OAuth client; add both in Google Cloud Console):
#   {AUTH_URL}/api/integrations/search-console/callback
#   {AUTH_URL}/api/integrations/ga4/callback
# Enable Analytics Data API for GA4 sync; OAuth consent must include scope analytics.readonly.
GOOGLE_SEARCH_CONSOLE_CLIENT_ID=
GOOGLE_SEARCH_CONSOLE_CLIENT_SECRET=

# Legacy only: old rows may still store gen.pollinations.ai URLs — proxy needs a key, or run npm run backfill:images
# POLLINATIONS_API_KEY=
# POLLINATIONS_PUBLISHABLE_KEY=

# Bootstrap admin (used by prisma/seed.ts — hashed on each seed run)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-strong-password

# Demo client (optional — seed creates CLIENT + active SEO subscription + backlink rows)
CLIENT_EMAIL=client@example.com
CLIENT_PASSWORD=change-me-client-password

# Phase 4 — monthly executive email (Resend) + Vercel/manual cron
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL="AI SEO Tool <reports@your-verified-domain.com>"
# CRON_SECRET=long-random-string-for-Authorization-Bearer-on-/api/cron/monthly-report
