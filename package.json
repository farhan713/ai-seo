{
  "name": "aiseotool",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbopack",
    "build": "prisma generate && next build --turbopack",
    "build:netlify": "prisma generate && next build",
    "netlify:login": "npx --yes netlify-cli@21.0.0 login",
    "netlify:link": "npx --yes netlify-cli@21.0.0 link",
    "netlify:deploy": "npx --yes netlify-cli@21.0.0 deploy --build --prod",
    "netlify:deploy:draft": "npx --yes netlify-cli@21.0.0 deploy --build",
    "docker:build": "docker build -t aiseotool .",
    "docker:up": "docker compose up -d --build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "demo:content": "tsx scripts/seed-demo-content.ts",
    "demo:social": "tsx scripts/seed-demo-content.ts --social-only",
    "backfill:images": "tsx scripts/backfill-creative-images.ts",
    "backfill:meta": "tsx scripts/backfill-blog-meta.ts",
    "docs:client-guide-docx": "node scripts/generate-client-guide-docx.mjs",
    "docs:user-guides-docx": "node scripts/generate-user-guides-docx.mjs",
    "probe:gemini-campaign": "tsx scripts/probe-gemini-campaign.ts",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@google/genai": "^1.46.0",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^3.0.3",
    "googleapis": "^171.4.0",
    "next": "15.5.14",
    "next-auth": "^5.0.0-beta.30",
    "pdfkit": "^0.18.0",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@netlify/plugin-nextjs": "^5.15.9",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pdfkit": "^0.17.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "docx": "^9.6.1",
    "eslint": "^9",
    "eslint-config-next": "15.5.14",
    "prisma": "^6.19.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
